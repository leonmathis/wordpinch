# Copy to .env.local and fill in. .env.local is gitignored.
# Find these values at:
#   https://supabase.com/dashboard/project/<ref>/settings/api

# Public — sent to the browser. Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only — never expose. Bypasses RLS.
SUPABASE_SECRET_KEY=sb_secret_...
